        "whoami": true,
        "id": true
    },

    // manual updates
    "update.mode": "manual",

    "fountain.pdf.emboldenCharacterNames": true,
    "fountain.pdf.printNotes": true,
    "fountain.pdf.sceneContinuationBottom": true,
    "fountain.pdf.sceneContinuationTop": true,
    //"fountain.pdf.showDialogueNumbers": true,

