    //"python.defaultInterpreterPath": "/var/home/wturner/-wrk/-ve311/memegen",
    //"python.defaultInterpreterPath": "/var/home/wturner/-wrk/-ve311/nbmeta/bin/python3",
    //"python.defaultInterpreterPath": "/var/home/wturner/-wrk/-ve311/tutorfin",
    //"python.defaultInterpreterPath": "/var/home/wturner/-wrk/-ve311/rblx",


    "roo-cline.debug": false,
    "docker.extension.dockerEngineAvailabilityPrompt": false,
    "chat.tools.terminal.autoApprove": {
        "true": true,
        "/^python3 -V$/": {
